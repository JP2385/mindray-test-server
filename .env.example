# Copiar este archivo como .env y completar los valores.
# .env nunca se sube al repositorio.
# En producción, setup.sh genera este archivo automáticamente.

# URL del endpoint de ingestión de vitales
# Producción:
INGEST_URL=https://api-reda.fly.dev/api/vitals/ingest
# Dev local:
# INGEST_URL=http://localhost:3000/api/vitals/ingest

# Nivel de log: DEBUG | INFO | WARNING (default: INFO)
# LOG_LEVEL=DEBUG
